{
  "name": "rail-rider",
  "version": "0.0.0",
  "description": "A 3D San Diego MTS Trolley driving simulator for operator training.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "predev": "npm run sync:data",
    "build": "tsc --noEmit && vite build",
    "prebuild": "npm run sync:data",
    "preview": "vite preview --host",
    "pipeline": "node pipeline/src/gtfsToTracks.ts",
    "sync:data": "node scripts/sync-data.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "@types/three": "^0.169.0",
    "typescript": "^5.6.0",
    "vite": "^7.1.0",
    "vitest": "^3.2.0"
  }
}
